# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by the application (via godotenv).
# Values set in the real environment always override .env values.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=ainyx_db
DB_SSLMODE=disable

SERVER_PORT=8080

# Set to "production" for JSON log output; anything else uses coloured dev logs.
APP_ENV=development
